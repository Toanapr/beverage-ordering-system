# Application Settings
NODE_ENV=test
PORT=3001
API_PREFIX=api/v1

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=beverage_ordering_test
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beverage_ordering_test?schema=public"

# JWT Authentication Configuration
JWT_ACCESS_SECRET=test_jwt_access_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./uploads_test
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp

# Rate Limiting Settings
THROTTLE_TTL=60
THROTTLE_LIMIT=100

CLIENT_URL=http://localhost:5173
